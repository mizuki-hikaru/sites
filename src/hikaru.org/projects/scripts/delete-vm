#!/usr/bin/env bash
set -euo pipefail

# --- Setup Cleanup and Trap ---
TEMP_DIR=$(mktemp -d)
LOG_FILE="${TEMP_DIR}/error.log"

cleanup() {
    local exit_code=$?
    if [[ -n "${SUDO_PID:-}" ]]; then
        kill "$SUDO_PID" 2>/dev/null || true
    fi
    rm -rf "$TEMP_DIR"
    exit "$exit_code"
}
trap cleanup EXIT INT TERM

# --- Sudo Management ---
if ! sudo -n true 2>/dev/null; then
    echo "[+] Requesting sudo privileges"
    sudo -v </dev/tty
    while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &
    SUDO_PID=$!
fi

# --- User Input ---
while true; do
    read -rp "VM Name to delete: " VM_NAME </dev/tty
    if [[ -z "$VM_NAME" ]]; then
        echo "[-] Name cannot be empty"
        continue
    fi
    if ! sudo virsh dominfo "$VM_NAME" >/dev/null 2>&1; then
        echo "[-] VM '${VM_NAME}' does not exist."
        exit 1
    else
        break
    fi
done

# --- Step Execution Helper ---
run_step() {
    local msg="$1"
    shift
    echo "$msg"
    if ! sudo "$@" >"$LOG_FILE" 2>&1; then
        echo "[-] Failed at step: $msg"
        echo "--- Error Log ---"
        cat "$LOG_FILE"
        exit 1
    fi
}

# --- Cleanup Steps ---
run_step "[+] Removing firewall rules for $VM_NAME" bash -c "
    # Clear any existing iptables rules for this VM in both nat and filter tables
    for table in nat filter; do
        iptables-save -t \$table | grep \"hikaru-vm-$VM_NAME\" | sed 's/^-A/iptables -t '\$table' -D/' | bash || true
    done
"

run_step "[+] Persisting firewall rules" netfilter-persistent save

run_step "[+] Removing entry from host /etc/hosts" sed -i "/[[:space:]]$VM_NAME\(\.local\)\?$/d" /etc/hosts

echo "[+] Destroying VM"
if sudo virsh domstate "$VM_NAME" | grep -q running; then
    run_step "[+] Stopping VM" virsh destroy "$VM_NAME"
fi
run_step "[+] Removing VM and storage" virsh undefine "$VM_NAME" --remove-all-storage

echo "[+] VM '$VM_NAME' successfully deleted."
