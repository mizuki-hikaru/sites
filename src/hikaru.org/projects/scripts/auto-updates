#!/usr/bin/env bash
set -euo pipefail

# --- Setup Cleanup and Trap ---
TEMP_DIR=$(mktemp -d)
LOG_FILE="${TEMP_DIR}/error.log"

cleanup() {
    local exit_code=$?
    if [[ -n "${SUDO_PID:-}" ]]; then
        kill "$SUDO_PID" 2>/dev/null || true
    fi
    rm -rf "$TEMP_DIR"
    exit "$exit_code"
}
trap cleanup EXIT INT TERM

# --- Sudo Management ---
if ! sudo -n true 2>/dev/null; then
    echo "[+] Requesting sudo privileges"
    sudo -v </dev/tty
    while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &
    SUDO_PID=$!
fi

# --- Step Execution Helper ---
run_step() {
    local msg="$1"
    shift
    echo "$msg"
    if ! sudo "$@" >"$LOG_FILE" 2>&1; then
        echo "[-] Failed at step: $msg"
        echo "--- Error Log ---"
        cat "$LOG_FILE"
        exit 1
    fi
}

# --- Steps ---
run_step "[+] Updating package lists" apt update
run_step "[+] Installing unattended-upgrades" apt install -y unattended-upgrades apt-listchanges

run_step "[+] Configuring periodic upgrades" bash -c "tee /etc/apt/apt.conf.d/22auto-upgrades-local >/dev/null <<'EOF'
APT::Periodic::Update-Package-Lists \"1\";
APT::Periodic::Unattended-Upgrade \"1\";
APT::Periodic::Download-Upgradeable-Packages \"1\";
APT::Periodic::AutocleanInterval \"7\";
EOF
"

run_step "[+] Configuring custom upgrade policies" bash -c "tee /etc/apt/apt.conf.d/52custom-unattended-upgrades >/dev/null <<'EOF'
Unattended-Upgrade::Remove-Unused-Dependencies \"true\";
Unattended-Upgrade::Automatic-Reboot \"true\";
Unattended-Upgrade::Automatic-Reboot-Time \"03:00\";
EOF
"

run_step "[+] Enabling unattended-upgrades service" systemctl enable --now unattended-upgrades
run_step "[+] Restarting unattended-upgrades service" systemctl restart unattended-upgrades

echo "[+] Automatic updates enabled"
echo
echo "To test:"
echo "  sudo unattended-upgrade --dry-run --debug"
echo
echo "To inspect timers:"
echo "  systemctl list-timers 'apt*'"
