#!/usr/bin/env bash
set -euo pipefail

# --- Setup Cleanup and Trap ---
TEMP_DIR=$(mktemp -d)
USER_DATA="${TEMP_DIR}/user-data"
META_DATA="${TEMP_DIR}/meta-data"
LOG_FILE="${TEMP_DIR}/error.log"

cleanup() {
    local exit_code=$?
    # Kill background sudo keep-alive
    if [[ -n "${SUDO_PID:-}" ]]; then
        kill "$SUDO_PID" 2>/dev/null || true
    fi
    # Remove temp files
    rm -rf "$TEMP_DIR"
    exit "$exit_code"
}
trap cleanup EXIT INT TERM

# --- Sudo Management ---
if ! sudo -n true 2>/dev/null; then
    echo "[+] Requesting sudo privileges"
    sudo -v </dev/tty
    # Keep-alive: update existing sudo time stamp until script has finished
    while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &
    SUDO_PID=$!
fi

# --- User Input ---
while true; do
    read -rp "VM Name: " VM_NAME </dev/tty
    if [[ -z "$VM_NAME" ]]; then
        echo "[-] Name cannot be empty"
        continue
    fi
    if sudo [ -f "/var/lib/libvirt/images/${VM_NAME}.qcow2" ]; then
        echo "[-] A VM with name '${VM_NAME}' already exists. Please choose a different name."
    else
        break
    fi
done

read -rp "Username [$USER]: " USERNAME </dev/tty
USERNAME=${USERNAME:-$USER}

read -rp "RAM (MB) [2048]: " VM_RAM_MB </dev/tty
VM_RAM_MB=${VM_RAM_MB:-2048}

read -rp "CPUs [2]: " VM_CPUS </dev/tty
VM_CPUS=${VM_CPUS:-2}

read -rp "Disk Size [20G]: " VM_DISK_SIZE </dev/tty
VM_DISK_SIZE=${VM_DISK_SIZE:-20G}

read -rp "Ports [none, e.g. 80,443]: " PORTS </dev/tty
PORTS=${PORTS:-none}

if [[ "$PORTS" != "none" ]]; then
    IFS=',' read -ra PORT_ARRAY <<< "$PORTS"
fi

# --- Configuration ---
CLOUD_IMG_URL="https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
BASE_IMG="/var/lib/libvirt/images/ubuntu-24.04-base.qcow2"
VM_DISK="/var/lib/libvirt/images/${VM_NAME}.qcow2"

# --- Step Execution Helper ---
run_step() {
    local msg="$1"
    shift
    echo "$msg"
    if ! sudo "$@" >"$LOG_FILE" 2>&1; then
        echo "[-] Failed at step: $msg"
        echo "--- Error Log ---"
        cat "$LOG_FILE"
        exit 1
    fi
}

echo
echo "[+] Detecting public key"
if [[ -f "$HOME/.ssh/id_ed25519.pub" ]]; then
    PUBKEY=$(<"$HOME/.ssh/id_ed25519.pub")
elif [[ -f "$HOME/.ssh/id_rsa.pub" ]]; then
    PUBKEY=$(<"$HOME/.ssh/id_rsa.pub")
else
    echo "[-] No SSH public key found in $HOME/.ssh/"
    exit 1
fi

run_step "[+] Installing packages" apt update
run_step "[+] Pre-configuring iptables-persistent" bash -c "echo iptables-persistent iptables-persistent/autosave_v4 boolean true | debconf-set-selections && echo iptables-persistent iptables-persistent/autosave_v6 boolean true | debconf-set-selections"
run_step "[+] Installing dependencies" bash -c "DEBIAN_FRONTEND=noninteractive apt install --no-install-recommends -y \
  qemu-system-x86 \
  qemu-utils \
  libvirt-daemon-system \
  libvirt-clients \
  virtinst \
  cloud-image-utils \
  wget \
  iptables-persistent"

run_step "[+] Enabling libvirtd" systemctl enable --now libvirtd
run_step "[+] Updating group memberships" usermod -aG kvm,libvirt "$USER"
run_step "[+] Enabling IP forwarding" sysctl -w net.ipv4.ip_forward=1

if [ ! -f "$BASE_IMG" ]; then
  run_step "[+] Fetching base image" wget -q -O "$BASE_IMG" "$CLOUD_IMG_URL"
fi

echo "[+] Preparing cloud-init configuration"
read -r -d '' TEMPLATE <<'EOF' || true
#cloud-config

hostname: VM_NAME
fqdn: VM_NAME.local

users:
  - name: USERNAME
    groups: sudo
    shell: /bin/bash
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    ssh_authorized_keys:
      - PUBKEY

packages:
  - avahi-daemon
  - libnss-mdns

write_files:
  - path: /etc/sudoers.d/90-nopasswd-sudo
    permissions: '0440'
    content: |
      %sudo ALL=(ALL) NOPASSWD:ALL
EOF

RESULT="${TEMPLATE//VM_NAME/$VM_NAME}"
RESULT="${RESULT//USERNAME/$USERNAME}"
RESULT="${RESULT//PUBKEY/$PUBKEY}"

printf '%s\n' "$RESULT" > "$USER_DATA"

cat > "$META_DATA" <<EOF
instance-id: ${VM_NAME}
local-hostname: ${VM_NAME}
EOF

run_step "[+] Creating VM disk" qemu-img create -f qcow2 -F qcow2 \
  -b "$BASE_IMG" \
  "$VM_DISK" \
  "$VM_DISK_SIZE"

run_step "[+] Installing VM" virt-install \
  --name "$VM_NAME" \
  --memory "$VM_RAM_MB" \
  --vcpus "$VM_CPUS" \
  --disk "$VM_DISK",device=disk,bus=virtio \
  --cloud-init user-data="$USER_DATA",meta-data="$META_DATA" \
  --os-variant ubuntu24.04 \
  --virt-type kvm \
  --graphics none \
  --network network=default,model=virtio \
  --import \
  --noreboot \
  --noautoconsole

DOMAIN_XML="${TEMP_DIR}/${VM_NAME}.libvirt.xml"
run_step "[+] Exporting libvirt XML (persistent)" bash -c "virsh dumpxml --inactive \"$VM_NAME\" > \"$DOMAIN_XML\""
run_step "[+] Configuring VM restart policy" bash -c "
    sed -i -E 's|<on_poweroff>[^<]*</on_poweroff>|<on_poweroff>restart</on_poweroff>|' \"$DOMAIN_XML\"
    sed -i -E 's|<on_reboot>[^<]*</on_reboot>|<on_reboot>restart</on_reboot>|' \"$DOMAIN_XML\"
    sed -i -E 's|<on_crash>[^<]*</on_crash>|<on_crash>restart</on_crash>|' \"$DOMAIN_XML\"
"
run_step "[+] Applying updated libvirt XML" virsh define "$DOMAIN_XML"

run_step "[+] Enabling VM autostart" virsh autostart "$VM_NAME"

echo "[+] Starting VM and waiting for IP (this may take a minute)"
VM_IP=""
for i in {1..60}; do
    # Ensure VM is running. If not, try to start it.
    STATE=$(sudo virsh domstate "$VM_NAME" 2>/dev/null || echo "unknown")
    if [[ "$STATE" != *"running"* ]]; then
        sudo virsh start "$VM_NAME" >/dev/null 2>&1 || true
    fi

    # Try to get the IP
    VM_IP="$(
        (sudo virsh domifaddr "$VM_NAME" --source lease 2>/dev/null || true) |
        awk '/ipv4/ { sub("/.*", "", $4); print $4; exit }'
    )"

    [[ -n "$VM_IP" && "$STATE" == *"running"* ]] && break

    sleep 2
done

if [ -z "$VM_IP" ]; then
    echo "[-] Could not detect VM IP."
    exit 1
fi

echo "[+] Detected VM IP: $VM_IP"

# Detect external interface to prevent DNAT from catching outbound traffic
EXT_IF=$(ip route | grep default | awk '{print $5; exit}')

if [[ "$PORTS" != "none" ]]; then
    run_step "[+] Clearing existing firewall rules for $VM_NAME" bash -c "
        # Clear any existing iptables rules for this VM in both nat and filter tables
        for table in nat filter; do
            iptables-save -t \$table | grep \"hikaru-vm-$VM_NAME\" | sed 's/^-A/iptables -t '\$table' -D/' | bash || true
        done
    "

    for PORT in "${PORT_ARRAY[@]}"; do
        run_step "[+] Clearing firewall conflicts for port $PORT" bash -c "
            # Delete any existing rules for this port to keep it idempotent
            for table in nat filter; do
                iptables-save -t \$table | grep \"dport $PORT\" | grep \"hikaru-vm-\" | sed 's/^-A/iptables -t '\$table' -D/' | bash || true
            done
        "
        
        # External access: DNAT traffic to the VM
        run_step "[+] Setting up external access for port $PORT" \
            iptables -t nat -A PREROUTING -i "$EXT_IF" -p tcp --dport "$PORT" -j DNAT --to-destination "$VM_IP:$PORT" -m comment --comment "hikaru-vm-$VM_NAME"

        # Host access: When the host itself connects to its own IP or localhost
        HOST_IP=$(ip addr show "$EXT_IF" | grep -Po 'inet \K[\d.]+' | head -n1)
        run_step "[+] Setting up host access for port $PORT (localhost)" \
            iptables -t nat -A OUTPUT -d 127.0.0.1 -p tcp --dport "$PORT" -j DNAT --to-destination "$VM_IP:$PORT" -m comment --comment "hikaru-vm-$VM_NAME"
        run_step "[+] Setting up host access for port $PORT (host IP)" \
            iptables -t nat -A OUTPUT -d "$HOST_IP" -p tcp --dport "$PORT" -j DNAT --to-destination "$VM_IP:$PORT" -m comment --comment "hikaru-vm-$VM_NAME"

        # Forwarding: Ensure the packet is allowed through the filter (top of chain to override libvirt)
        run_step "[+] Setting up forwarding for port $PORT" \
            iptables -I FORWARD -d "$VM_IP" -p tcp --dport "$PORT" -j ACCEPT -m comment --comment "hikaru-vm-$VM_NAME"

        # Hairpin/Double NAT: Masquerade traffic to the VM so return path is guaranteed
        run_step "[+] Setting up masquerade for port $PORT" \
            iptables -t nat -A POSTROUTING -d "$VM_IP" -p tcp --dport "$PORT" -j MASQUERADE -m comment --comment "hikaru-vm-$VM_NAME"
    done
fi

run_step "[+] Persisting firewall rules" netfilter-persistent save

run_step "[+] Updating host /etc/hosts" bash -c "
    sed -i '/[[:space:]]$VM_NAME\(\.local\)\?$/d' /etc/hosts
    echo '$VM_IP $VM_NAME $VM_NAME.local' >> /etc/hosts
"

echo "[+] VM creation complete"

if ! groups "$USER" | grep -qE '\blibvirt\b'; then
    echo "[!] You will need to log out/in for libvirt group membership to apply."
fi
echo
echo "VM Name: $VM_NAME"
echo "VM IP: $VM_IP"
echo "mDNS: $VM_NAME.local"
echo
echo "Useful commands:"
echo "  virsh list --all"
echo "  virsh domifaddr $VM_NAME"
echo "  virsh console $VM_NAME"
echo "  virsh shutdown $VM_NAME"
echo "  virsh destroy $VM_NAME"
echo "  virsh undefine $VM_NAME --remove-all-storage"
